{
  "manifest_version": 3,
  "name": "yt-not-interested",
  "description": "Adds quick Watched and Not interested buttons on YouTube video thumbnails.",
  "version": "0.1.0",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://*.youtube.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "yt-not-interested@steamric.github.io",
      "strict_min_version": "121.0"
    }
  }
}
